<UserControl x:Class="LLMClient.Endpoints.OpenAIAPI.APIEndPointView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LLMClient.Endpoints.OpenAIAPI"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:LLMClient.Endpoints.Converters"
             xmlns:converters1="clr-namespace:LLMClient.Component.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance local:APIEndPoint}">
    <Grid>
        <Grid.Resources>
            <Style TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource MaterialDesignSubtitle2TextBlock}">
                <Setter Property="VerticalAlignment"
                        Value="Center" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid Grid.ColumnSpan="2"
              DataContext="{Binding Option,Mode=OneTime}">
            <Grid.Resources>
                <Style TargetType="{x:Type TextBlock}"
                       BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="VerticalAlignment"
                            Value="Bottom" />
                </Style>
                <Style TargetType="{x:Type TextBox}"
                       BasedOn="{StaticResource {x:Type TextBox}}">
                    <Setter Property="Margin"
                            Value="0,0,10,0" />
                    <Setter Property="VerticalContentAlignment"
                            Value="Bottom" />
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Display Name：" />
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding DisplayName,Mode=TwoWay}" />
            <Grid Grid.Row="1" Grid.ColumnSpan="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="API URL:" />
                <TextBox Grid.Column="1" Text="{Binding ConfigOption.URL,Mode=TwoWay}" />
                <TextBlock Grid.Column="2" Text="API Version:" />
                <TextBox Grid.Column="3" Text="{Binding ConfigOption.APIVersion,Mode=TwoWay, FallbackValue=v1}" />
                <TextBlock Grid.Column="4" Text="API Token:" />
                <TextBox Grid.Column="5" Text="{Binding ConfigOption.APIToken,Mode=TwoWay}" />
                <!--<ToggleButton Grid.Column="5"
                              Width="18"
                              Height="18"
                              Margin="6,0"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Right"
                              ToolTip="显示/隐藏"
                              Style="{StaticResource MaterialDesignActionLightToggleButton}"
                              Padding="0">
                    <materialDesign:PackIcon Width="14"
                                             Height="14"
                                             Kind="EyeOffOutline" />
                    <materialDesign:ToggleButtonAssist.OnContent>
                        <materialDesign:PackIcon Width="14"
                                                 Height="14"
                                                 Kind="EyeOutline" />
                    </materialDesign:ToggleButtonAssist.OnContent>
                </ToggleButton>-->
            </Grid>
            <TextBlock Grid.Row="0" Grid.Column="2"
                       Text="Icon URL:" />
            <TextBox Grid.Row="0" Grid.Column="3"
                     Text="{Binding IconUrl,Mode=TwoWay}" />
            <Grid Grid.Row="2"
                  Grid.Column="0"
                  Grid.ColumnSpan="4"
                  Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Source:" />

                <ComboBox Grid.Row="0"
                          Grid.Column="1"
                          VerticalAlignment="Bottom"
                          HorizontalAlignment="Stretch"
                          SelectedValue="{Binding ModelsSource,Mode=TwoWay}"
                          Width="80">
                    <ComboBox.Items>
                        <converters:ModelSource>None</converters:ModelSource>
                        <converters:ModelSource>OpenRouter</converters:ModelSource>
                        <converters:ModelSource>GeekAI</converters:ModelSource>
                        <converters:ModelSource>O3Fan</converters:ModelSource>
                        <converters:ModelSource>NewAPI</converters:ModelSource>
                    </ComboBox.Items>
                </ComboBox>

                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="API Usage Url:">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}"
                               BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModelsSource,Mode=OneWay}"
                                             Value="{x:Static converters:ModelSource.NewAPI}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Grid.Row="0"
                         Grid.Column="3"
                         Grid.ColumnSpan="3"
                         Text="{Binding ApiLogUrl,Mode=TwoWay}">
                    <TextBox.Style>
                        <Style TargetType="{x:Type TextBox}"
                               BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Margin" Value="6,0,10,0" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModelsSource,Mode=OneWay}"
                                             Value="{x:Static converters:ModelSource.NewAPI}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="System Token：">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}"
                               BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModelsSource,Mode=OneWay}"
                                             Value="{x:Static converters:ModelSource.NewAPI}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Grid.Row="0"
                         Grid.Column="3"
                         Text="{Binding NewApiSystemToken,Mode=TwoWay}">
                    <TextBox.Style>
                        <Style TargetType="{x:Type TextBox}"
                               BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Margin" Value="6,0,10,0" />
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModelsSource,Mode=OneWay}"
                                             Value="{x:Static converters:ModelSource.NewAPI}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock Grid.Row="0"
                           Grid.Column="4"
                           Margin="0,0,0,0"
                           Text="User Id：">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}"
                               BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModelsSource,Mode=OneWay}"
                                             Value="{x:Static converters:ModelSource.NewAPI}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Grid.Row="0"
                         Grid.Column="5"
                         Margin="6,0,10,0"
                         Text="{Binding NewApiUserId,Mode=TwoWay}">
                    <TextBox.Style>
                        <Style TargetType="{x:Type TextBox}"
                               BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Margin" Value="6,0,10,0" />
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModelsSource,Mode=OneWay}"
                                             Value="{x:Static converters:ModelSource.NewAPI}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Row="0"
                        Grid.Column="6"
                        Width="30"
                        Height="30"
                        Margin="6,0,0,0"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"
                        ToolTip="同步模型"
                        Content="{materialDesign:PackIcon Kind=Refresh}"
                        Command="{Binding RefreshModelSource}">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}"
                               BasedOn="{StaticResource MaterialDesignFloatingActionMiniButton}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModelsSource,Mode=OneWay}"
                                             Value="{x:Static converters:ModelSource.NewAPI}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ModelsSource,Mode=OneWay}"
                                             Value="{x:Static converters:ModelSource.None}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Proxy:" />
            <StackPanel Grid.Row="3"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        DataContext="{Binding ConfigOption,Mode=OneTime}">
                <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              ToolTip="Use Custom configuration as proxy settings"
                              IsChecked="{Binding  ProxySetting.UseGlobalProxy,Mode=TwoWay,Converter={StaticResource InvertBooleanConverter}}" />
                <TextBlock Text="独立配置："
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
                <materialDesign:PopupBox PopupContent="{Binding ProxySetting.ProxyOption,Mode=OneTime}"
                                         PopupContentTemplate="{StaticResource ProxyOptionDataTemplate}"
                                         PlacementMode="TopAndAlignLeftEdges"
                                         IsEnabled="{Binding  ProxySetting.UseGlobalProxy,Mode=OneWay,Converter={StaticResource InvertBooleanConverter}}"
                                         Padding="10"
                                         ToggleContent="{materialDesign:PackIcon Kind=ProxyOutline}"
                                         PopupElevation="Dp4"
                                         PopupUniformCornerRadius="8"
                                         ToolTip="代理"
                                         StaysOpen="True"
                                         VerticalAlignment="Center"
                                         Style="{StaticResource MaterialDesignToolPopupBox}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="2"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom">
                <CheckBox VerticalAlignment="Center"
                          IsChecked="{Binding ConfigOption.IsOpenAICompatible,Mode=TwoWay}"
                          materialDesign:CheckBoxAssist.CheckBoxSize="30"
                          Height="35"
                          Content="OpenAI Compatible" />
                <CheckBox VerticalAlignment="Center"
                          IsChecked="{Binding ConfigOption.TreatNullChoicesAsEmptyResponse,Mode=TwoWay}"
                          ToolTip="仅对非流式响应生效：当部分 OpenAI-compatible 服务返回 choices:null 时，将其自动降级为空响应，而不是直接报错。"
                          materialDesign:CheckBoxAssist.CheckBoxSize="30"
                          Height="35"
                          Content="Null choices fallback" />
            </StackPanel>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Http Headers:" />
            <TextBox Grid.Row="4" Grid.Column="1"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,6,0,0"
                     Padding="6,2"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Left"
                     MinHeight="30"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     MaxHeight="100"
                     Text="{Binding ConfigOption.AdditionalHeaders,Mode=OneWay,Converter={x:Static converters1:SnapConverters.ObjectToPrettyJsonConverter}}" />
            <Button Grid.Row="4" Grid.Column="1"
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Content="{materialDesign:PackIcon Kind=ReceiptTextEdit,Size=15}"
                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                    Command="{Binding  ConfigOption.ConfigHeadersCommand}" />
        </Grid>
        <ListBox Grid.Row="1" Grid.Column="0"
                 Margin="0,16,0,0"
                 x:Name="ModelsListBox"
                 IsSynchronizedWithCurrentItem="True"
                 SelectedIndex="{Binding SelectedModelIndex,Mode=TwoWay}"
                 ItemsSource="{Binding Option.Models,Mode=OneWay}">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="{Binding PastCommand}"
                              Icon="{materialDesign:PackIcon Kind=ContentPaste}"
                              Header="黏贴" />
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}"
                       BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="HorizontalContentAlignment"
                            Value="Stretch" />
                    <Setter Property="VerticalContentAlignment"
                            Value="Stretch" />
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Command="{Binding CopyCommand}"
                                          Icon="{materialDesign:PackIcon Kind=ContentCopy}"
                                          Header="复制" />
                                <MenuItem Command="Paste"
                                          Icon="{materialDesign:PackIcon Kind=ContentPaste}"
                                          Header="黏贴到之后" />
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type local:APIModelInfo}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Image Source="{Binding Icon.CurrentSource,Mode=OneWay}"
                               Width="25"
                               Height="25" />
                        <materialDesign:PackIcon Grid.Column="0"
                                                 Width="15"
                                                 Height="15"
                                                 Foreground="Red"
                                                 Visibility="{Binding IsNotMatchFromSource,Mode=OneWay,Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 VerticalAlignment="Bottom"
                                                 HorizontalAlignment="Right"
                                                 Kind="AlertCircleOutline" />
                        <TextBlock Grid.Column="1" Text="{Binding Name,Mode=OneWay}"
                                   Margin="6,0,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Width="22"
                                Height="22"
                                Background="White"
                                Command="MoveUp"
                                CommandParameter="{Binding}"
                                Style="{StaticResource ListBoxHoverButtonStyle}">
                            <materialDesign:PackIcon Kind="ArrowUpBold"
                                                     Width="17"
                                                     Height="17" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.CommandBindings>
                <CommandBinding Command="MoveUp"
                                Executed="MoveUp_OnExecuted" />
                <CommandBinding Command="Paste"
                                Executed="PastModels_OnExecuted" />
            </ListBox.CommandBindings>
        </ListBox>
        <Separator Grid.Row="1" Grid.Column="0"
                   Grid.ColumnSpan="2"
                   VerticalAlignment="Top"
                   Margin="0,6" />
        <ContentControl Grid.Row="1" Grid.Column="1"
                        Margin="10,16,0,0"
                        Visibility="{Binding ElementName=ModelsListBox,Path=SelectedItem,Mode=OneWay,Converter={x:Static materialDesign:NullableToVisibilityConverter.CollapsedInstance}}"
                        Content="{Binding ElementName=ModelsListBox,Path=SelectedItem,Mode=OneWay}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type local:APIModelInfo}">
                    <ScrollViewer>
                        <local:APIModelInfoConfigView Margin="0,0,10,0" />
                    </ScrollViewer>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
        <Button Grid.Row="1" Grid.Column="0"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Width="30"
                Height="30"
                Margin="0,0,6,0"
                Command="{Binding AddNewCommand}"
                Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}"
                ToolTip="添加">
            <materialDesign:PackIcon Kind="Add"
                                     Width="20"
                                     Height="20" />
        </Button>
        <Button Grid.Row="1" Grid.Column="0"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Left"
                Width="30"
                Height="30"
                Margin="6,0,0,0"
                Command="{Binding RemoveCommand}"
                Visibility="{Binding ElementName=ModelsListBox,Path=SelectedItem,Converter={x:Static materialDesign:NullableToVisibilityConverter.CollapsedInstance}}"
                CommandParameter="{Binding ElementName=ModelsListBox,Path=SelectedItem}"
                Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}"
                ToolTip="移除">
            <materialDesign:PackIcon Kind="Minus"
                                     Width="20"
                                     Height="20" />
        </Button>
    </Grid>
</UserControl>