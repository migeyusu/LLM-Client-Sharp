<UserControl x:Class="LLMClient.Endpoints.EndpointConfigureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:azure="clr-namespace:LLMClient.Endpoints.Azure"
             xmlns:endpoints="clr-namespace:LLMClient.Endpoints"
             xmlns:openAiapi="clr-namespace:LLMClient.Endpoints.OpenAIAPI"
             xmlns:abstraction="clr-namespace:LLMClient.Abstraction"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance endpoints:EndpointConfigureViewModel}"
             d:DesignHeight="500" d:DesignWidth="600"
             x:Name="ControlRoot">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"
                           MaxHeight="200" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!--Style="{StaticResource MaterialDesignChoiceChipListBox}"-->
        <Grid Margin="12,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <materialDesign:PopupBox Grid.Column="0"
                                     Margin="5"
                                     ToolTip="添加新的LLM服务"
                                     ToolTipService.InitialShowDelay="0"
                                     PlacementMode="BottomAndAlignCentres"
                                     VerticalAlignment="Center"
                                     materialDesign:ElevationAssist.Elevation="Dp4"
                                     Width="30"
                                     Height="30"
                                     Style="{StaticResource MaterialDesignMultiFloatingActionPopupBox}">
                <materialDesign:PopupBox.ToggleCheckedContent>
                    <materialDesign:PackIcon Width="20"
                                             Height="20"
                                             Kind="Pencil"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Center" />
                </materialDesign:PopupBox.ToggleCheckedContent>
                <StackPanel>
                    <Button ToolTip="OpenAI API兼容"
                            Margin="10"
                            materialDesign:ElevationAssist.Elevation="Dp4"
                            Command="{Binding AddNewEndpointCommand}">
                        <Button.Content>
                            <materialDesign:PackIcon Kind="Api"
                                                     Foreground="White"
                                                     Width="23"
                                                     Height="23" />
                        </Button.Content>
                    </Button>
                </StackPanel>
            </materialDesign:PopupBox>
            <ListBox Grid.Column="1"
                     Margin="10"
                     ItemsSource="{Binding Endpoints,Mode=OneWay}"
                     SelectionMode="Single"
                     Style="{StaticResource MaterialDesignChoiceChipPrimaryOutlineListBox}"
                     SelectedItem="{Binding SelectedEndpoint,Mode=OneWayToSource}"
                     MaxHeight="120"
                     BorderBrush="DarkGray"
                     BorderThickness="0,0,0,1">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type abstraction:ILLMAPIEndpoint}">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20"
                                   Height="20"
                                   Source="{Binding Icon.CurrentSource,Mode=OneWay}" />
                            <TextBlock Text="{Binding DisplayName,Mode=OneWay}"
                                       MaxWidth="120"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                            <Border
                                Visibility="{Binding RelativeSource={RelativeSource FindAncestor,AncestorType=ListBoxItem},Path=IsSelected,Mode=OneWay,Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton Width="18"
                                                  Height="18"
                                                  Margin="6,0,0,0"
                                                  VerticalAlignment="Center"
                                                  ToolTip="禁用/启用"
                                                  IsChecked="{Binding IsDisabled,Mode=OneWay}"
                                                  Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListBox},Path=DataContext.ToggleEndpointDisabledCommand}"
                                                  CommandParameter="{Binding}"
                                                  Style="{StaticResource MaterialDesignActionLightToggleButton}"
                                                  Padding="0">
                                        <materialDesign:PackIcon Width="14"
                                                                 Height="14"
                                                                 Kind="EyeOffOutline" />
                                        <materialDesign:ToggleButtonAssist.OnContent>
                                            <materialDesign:PackIcon Width="14"
                                                                     Height="14"
                                                                     Kind="EyeOutline" />
                                        </materialDesign:ToggleButtonAssist.OnContent>
                                    </ToggleButton>
                                    <Button Width="18"
                                            Height="18"
                                            Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListBox},Path=DataContext.RemoveEndPointCommand}"
                                            CommandParameter="{Binding  }"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="删除当前"
                                            Visibility="{Binding  IsInbuilt,Mode=OneTime,Converter={x:Static materialDesign:BooleanToVisibilityConverter.NotCollapsedInstance}}"
                                            Template="{StaticResource ItemDeleteButtonTemplate}">
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem"
                           BasedOn="{StaticResource MaterialDesignChoiceChipPrimaryOutlineListBoxItem}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                <Setter Property="Opacity" Value="0.4" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Grid.Column="2"
                    Style="{StaticResource PopupCloseButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="5" />
        </Grid>
        <ContentControl Grid.Row="1"
                        Margin="16,0,16,5"
                        Padding="0"
                        Content="{Binding SelectedEndpoint,Mode=OneWay}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type azure:GithubCopilotEndPoint}">
                    <azure:GithubCopilotEndPointView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type openAiapi:APIEndPoint}">
                    <openAiapi:APIEndPointView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
        <Separator Grid.Row="2"
                   Background="Black"
                   VerticalAlignment="Top"
                   Margin="10,0" />
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="10,4,10,8">
            <Button Content="重置"
                    Margin="0,0,10,0"
                    Command="{Binding ReloadCommand}" />
            <Button Content="保存全部"
                    Command="{Binding SaveAllCommand}"
                    CommandParameter="{Binding ElementName=ControlRoot}" />
        </StackPanel>
    </Grid>
</UserControl>