<Window x:Class="LLMClient.Component.CustomControl.CustomMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Title="Message">
    <materialDesign:Card UniformCornerRadius="8" Margin="15" Padding="20" 
                         Background="{DynamicResource MaterialDesignPaper}"
                         materialDesign:ElevationAssist.Elevation="Dp4"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource MaterialDesignDivider}">
        <Grid MaxWidth="500" MinWidth="350">
             <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Header/Icon -->
             <Grid Grid.Row="0" Margin="0,0,0,10" MouseLeftButtonDown="Title_MouseLeftButtonDown" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon x:Name="IconControl" Kind="Information" Width="28" Height="28" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                <TextBlock x:Name="TitleTextBlock" Grid.Column="1" Text="Title" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
            </Grid>

            <!-- Message -->
            <TextBlock x:Name="MessageTextBlock" Grid.Row="1" Text="Message Content" TextWrapping="Wrap" Margin="0,10,0,20" Style="{StaticResource MaterialDesignBody1TextBlock}" FontSize="14"/>

            <!-- Buttons -->
            <StackPanel  Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Margin="8,0,0,0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="CancelButton_Click" Visibility="Collapsed"/>
                <Button x:Name="NoButton" Content="No" Margin="8,0,0,0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="NoButton_Click" Visibility="Collapsed"/>
                <Button x:Name="YesButton" Content="Yes" Margin="8,0,0,0" Style="{StaticResource MaterialDesignFlatMidBgButton}" Click="YesButton_Click" Visibility="Collapsed"/>
                <Button x:Name="OkButton" Content="OK" Margin="8,0,0,0" Style="{StaticResource MaterialDesignFlatMidBgButton}" Click="OkButton_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</Window>
