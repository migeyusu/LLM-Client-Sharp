                                      Width="18"
                                      Height="45"
                                      Padding="0">
                                <MenuItem Header="删除其他回复"
                                          Icon="{materialDesign:PackIcon Kind=Clear}"
                                          Visibility="{Binding IsMultiResponse,Mode=OneWay,Converter={StaticResource BooleanToVisibilityConverter}}"
                                          Command="{Binding ClearOthersCommand}" />
