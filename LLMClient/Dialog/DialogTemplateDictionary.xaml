                                            Height="16"
                                            VerticalAlignment="Center"
                                            Margin="6,0,-6,0"
                                            Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListBox},Path=DataContext.RemoveResponseCommand}"
                                            CommandParameter="{Binding  }"
