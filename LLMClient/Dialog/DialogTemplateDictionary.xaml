                                            Visibility="{Binding IsResponding,Mode=OneWay,Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Command="{Binding CancelCommand}"
                                            Style="{StaticResource ResponseCancelButtonStyle}" />
