                                <MenuItem Header="查看协议日志"
                                          ToolTip="查看详细过程日志"
                                          Command="{x:Static models:ResponseViewItemBase.ShowProtocolLogCommand}"
                                          CommandParameter="{Binding AcceptedResponse,Mode=OneWay}"
                                          Icon="{materialDesign:PackIcon Kind=History}" />
                                <MenuItem Header="保存协议日志"
                                          ToolTip="保存详细过程日志"
                                          Command="{x:Static models:ResponseViewItemBase.SaveProtocolLogCommand}"
                                          CommandParameter="{Binding AcceptedResponse,Mode=OneWay}"
                                          Icon="{materialDesign:PackIcon Kind=FileDocumentArrowRightOutline}" />
                                <MenuItem Header="标记为有效回复"
                                          IsCheckable="True"
                                          IsChecked="{Binding AcceptedResponse.IsManualValid,Mode=TwoWay}"
                                          Visibility="{Binding AcceptedResponse.IsInterrupt,Mode=OneWay,Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}" />
                                <MenuItem Command="{Binding AcceptedResponse.EliminateFailedHistoryCommand}"
                                          Header="剔除错误历史"
                                          ToolTip="剔除错误的工具调用" />
                                <MenuItem Command="{Binding AcceptedResponse.EliminateHistoryCommand}"
                                          Header="剔除交互历史"
                                          ToolTip="只保留最终消息" />
                            </MenuItem>
                        </Menu>
                        <materialDesign:PopupBox Padding="4,0"
                                                 StaysOpen="True"
                                                 PopupUniformCornerRadius="8"
                                                 VerticalAlignment="Center"
                                                 ToolTip="分支导航"
                                                 Margin="10,0,0,0"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                 ToggleContent="{materialDesign:PackIcon Kind=DirectionsFork,Size=20}"
                                                 Style="{StaticResource MaterialDesignToolPopupBox}"
                                                 Opened="ForkNavigation_PopupBox_OnOpened"
                                                 PopupContent="{Binding ParentSession.SharedGraphViewModel,Mode=OneTime}"
                                                 Visibility="{Binding HasFork,Mode=OneWay,Converter={StaticResource BooleanToVisibilityConverter}}">
                            <materialDesign:PopupBox.PopupContentTemplate>
                                <DataTemplate DataType="{x:Type controls:DialogGraphViewModel}">
                                    <controls:DialogGraphControl DataContext="{Binding}"
                                                                 MaxHeight="800"
                                                                 MaxWidth="600" />
