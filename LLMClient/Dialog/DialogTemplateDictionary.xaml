            <DataTrigger Binding="{Binding IsResponding,Mode=OneWay}"
                         Value="True">
                <Setter Property="Visibility"
                        Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <DataTemplate x:Key="MultiResponseViewItemDataTemplate"
                  DataType="{x:Type models:ParallelResponseViewItem}">
