    <DataTemplate x:Key="ResponseProcTemplate"
                  DataType="{x:Type models:ResponseViewItemBase}">
        <StackPanel>
            <StackPanel Orientation="Horizontal"
                        Margin="0,6,0,0">
                <materialDesign:PackIcon Kind="Sync"
                                         Width="16"
                                         Height="16"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                    <materialDesign:PackIcon.RenderTransform>
                        <RotateTransform x:Name="StatusIconRotation"
                                         CenterX="8"
                                         CenterY="8" />
                    </materialDesign:PackIcon.RenderTransform>
                    <materialDesign:PackIcon.Style>
                        <Style TargetType="materialDesign:PackIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsResponding,Mode=OneWay}"
                                             Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                                    From="0"
                                                    To="360"
                                                    Duration="0:0:1.2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialDesign:PackIcon.Style>
                </materialDesign:PackIcon>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                           Text="{Binding  LoopCount,Mode=OneWay,StringFormat=🔄 轮 {0}}" />
                <TextBlock VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           MaxWidth="500"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                           Text="{Binding CurrentStatus,Mode=OneWay}"
                           Visibility="{Binding CurrentStatus,Mode=OneWay,Converter={x:Static materialDesign:NullableToVisibilityConverter.CollapsedInstance}}" />
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <Style TargetType="{x:Type ContentControl}"
           x:Key="ResponseProcStyle"
           d:DataContext="{d:DesignInstance models:RawResponseViewItem}">
        <Setter Property="ContentTemplate" Value="{StaticResource ResponseProcTemplate}" />
        <Setter Property="Visibility"
                Value="Collapsed" />
