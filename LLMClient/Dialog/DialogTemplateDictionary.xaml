    <DataTemplate x:Key="ContextUsageDetailDataTemplate"
                  DataType="{x:Type models:ContextUsageViewModel}">
        <StackPanel Margin="10"
                    MinWidth="240"
                    MaxWidth="320">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <materialDesign:PackIcon Width="18"
                                         Height="18"
                                         Margin="0,0,6,0"
                                         Kind="Gauge"
                                         VerticalAlignment="Center"
                                         Style="{StaticResource ContextUsageIndicatorIconStyle}" />
                <TextBlock Text="上下文占比"
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Text="{Binding ContextUsageSummary,Mode=OneWay}"
                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                       TextWrapping="Wrap" />
            <ProgressBar Margin="0,8,0,0"
                         Height="6"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ContextUsagePercent,Mode=OneWay}"
                         Style="{StaticResource ContextUsageIndicatorProgressBarStyle}" />
            <UniformGrid Columns="2"
                         Margin="0,10,0,0">
                <TextBlock Text="输入 Tokens"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}" />
                <TextBlock HorizontalAlignment="Right"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Text="{Binding ContextUsageTokenCount,Mode=OneWay,StringFormat={}{0:N0}}" />
                <TextBlock Text="最大上下文"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}" />
                <TextBlock HorizontalAlignment="Right"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Text="{Binding MaxContextTokens,Mode=OneWay,StringFormat={}{0:N0}}" />
                <TextBlock Text="当前占比"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}" />
                <TextBlock HorizontalAlignment="Right"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Text="{Binding ContextUsagePercent,Mode=OneWay,StringFormat={}{0:0}%}" />
            </UniformGrid>
            <TextBlock Margin="0,10,0,0"
                       Text="基于最后一次成功调用的输入 Tokens 与模型最大上下文计算。"
                       TextWrapping="Wrap"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}" />
            <TextBlock Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       Style="{StaticResource ContextUsageIndicatorHintStyle}" />
        </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="ResponseStatsTemplate"
                  DataType="{x:Type models:ResponseViewItemBase}">
        <StackPanel Orientation="Horizontal">
            <TextBlock HorizontalAlignment="Left"
                       Margin="0,6,0,0">
                <TextBlock.Text>
                    <MultiBinding
                        StringFormat="Completion Tokens: {0}, Price：{1:F4}$，Latency: {2}ms, Duration:{3}s, Speed:{4:F1}tps">
                        <Binding Path="Tokens"
                                 Mode="OneWay"
                                 TargetNullValue="None" />
                        <Binding Path="Price"
                                 Mode="OneWay"
                                 TargetNullValue="None" />
                        <Binding Path="Latency"
                                 Mode="OneWay"
                                 TargetNullValue="None" />
                        <Binding Path="Duration"
                                 Mode="OneWay"
                                 TargetNullValue="None" />
                        <Binding Path="TpS"
                                 Mode="OneWay"
                                 TargetNullValue="None" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
            <TextBlock Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding LoopCount,Mode=OneWay,StringFormat=🔄 {0} 轮}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LoopCount,Mode=OneWay}"
                                         Value="0">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LoopCount,Mode=OneWay}"
                                         Value="1">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <materialDesign:PopupBox ToolTip="总用量信息"
                                     Margin="10,0,0,0"
                                     Width="30"
                                     Height="30"
                                     Visibility="{Binding Usage,Mode=OneWay,Converter={x:Static materialDesign:NullableToVisibilityConverter.CollapsedInstance}}"
                                     ToggleContent="{materialDesign:PackIcon Kind=InfoOutline}"
                                     PopupAnimation="Slide"
                                     PopupUniformCornerRadius="8"
                                     Padding="4,0"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Center"
                                     PopupContent="{Binding Usage,Mode=OneWay}"
                                     PopupContentTemplate="{StaticResource UsageDetailDataTemplate}" />
            <materialDesign:PopupBox ToolTip="上下文占比"
                                     Margin="10,0,0,0"
                                     Padding="4,0"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding LastContextUsage.HasContextUsage,Mode=OneWay,Converter={StaticResource BooleanToVisibilityConverter}}"
                                     PopupAnimation="Slide"
                                     PopupUniformCornerRadius="8"
                                     PopupContent="{Binding LastContextUsage,Mode=OneWay}"
                                     PopupContentTemplate="{StaticResource ContextUsageDetailDataTemplate}">
                <materialDesign:PopupBox.ToggleContent>
                    <Border Padding="8,4"
                            CornerRadius="12"
                            DataContext="{Binding LastContextUsage,Mode=OneWay}"
                            Style="{StaticResource ContextUsageIndicatorBorderStyle}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <materialDesign:PackIcon Width="16"
                                                     Height="16"
                                                     Margin="0,0,4,0"
                                                     Kind="Gauge"
                                                     VerticalAlignment="Center"
                                                     Style="{StaticResource ContextUsageIndicatorIconStyle}" />
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource ContextUsageIndicatorTextStyle}"
                                       Text="{Binding ContextUsagePercent,Mode=OneWay,StringFormat={}{0:0}%}" />
                        </StackPanel>
                    </Border>
                </materialDesign:PopupBox.ToggleContent>
            </materialDesign:PopupBox>
        </StackPanel>
    </DataTemplate>
    <Style x:Key="ResponseStatsStyle"
           TargetType="{x:Type ContentControl}"
           d:DataContext="{d:DesignInstance models:ResponseViewItemBase}">
        <Setter Property="ContentTemplate"
                Value="{StaticResource ResponseStatsTemplate}" />
        <Setter Property="Visibility"
                Value="Visible" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsResponding,Mode=OneWay}"
                         Value="True">
                <Setter Property="Visibility"
                        Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <DataTemplate x:Key="ChatClientIdentityTemplate"
                  DataType="{x:Type abstraction:ILLMChatClient}">
        <StackPanel Orientation="Horizontal">
            <Image VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Source="{Binding Model.Icon.CurrentSource,Mode=OneWay}"
                   Width="26"
                   Height="26" />
            <TextBlock Text="{Binding Name,Mode=OneTime}"
