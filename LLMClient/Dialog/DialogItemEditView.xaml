<UserControl x:Class="LLMClient.Dialog.DialogItemEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:LLMClient.Dialog"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:DialogItemEditViewModel}"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ContentPresenter x:Name="Editor"
                          Content="{Binding SelectedTextContent,Mode=OneWay}"
                          ContentTemplateSelector="{StaticResource TextEditTemplateSelector}" />
        <ComboBox Grid.Row="1"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Width="200"
                  Visibility="{Binding IsMultiContent,Mode=OneTime, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}"
                  ItemsSource="{Binding TextContents,Mode=OneTime}"
                  DisplayMemberPath="FinalText"
                  SelectedItem="{Binding SelectedTextContent,Mode=TwoWay}"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}" />
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="5">
            <Button Content="{materialDesign:PackIcon Kind=FileDocumentPlusOutline}"
                    Command="{Binding SelectedTextContent.AddCodeFileCommand}"
                    CommandParameter="{Binding ElementName=Editor}"
                    Visibility="{Binding SelectedTextContent, Converter={x:Static materialDesign:NullableToVisibilityConverter.CollapsedInstance}}"
                    Margin="0,0,8,0"
                    ToolTip="Add file as code block" />
            <Button Content="确认更改"
                    Command="{Binding  SaveCommand}" />
        </StackPanel>
    </Grid>
</UserControl>